# ===== Telegram =====
# Lấy token từ @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_NAME=Media AI Hub Shop

# Liên hệ hỗ trợ hiển thị trong menu Hỗ trợ
SUPPORT_CONTACT=@your_admin

# ID Telegram của admin (gõ /myid trong bot để lấy). Nhiều admin: ngăn cách bằng dấu phẩy
ADMIN_ID=123456789

# Mật khẩu đăng nhập trang quản trị web /admin
ADMIN_PASSWORD=change-this-strong-password

# ===== Chế độ chạy =====
# URL công khai của app trên Hostinger (dùng cho webhook)
PUBLIC_URL=https://antiquewhite-ram-556370.hostingersite.com
# Đặt true để chạy long-polling khi test ở máy local (Hostinger để trống = webhook)
USE_POLLING=false

# Thư mục data bền vững. Khuyến nghị đặt ngoài thư mục app trên Hostinger
# Ví dụ: /home/<username>/bot-data
DATA_DIR=

# Quản lý nhiều bot trên 1 trang admin (tùy chọn).
# Mỗi bot chạy riêng với BOT_TOKEN + DATA_DIR riêng; admin đọc trực tiếp các thư mục data.
# Ví dụ (1 dòng JSON, không xuống dòng):
# BOTS_CONFIG=[{"id":"shop1","name":"Media AI Hub","dataDir":"/home/u123/bot-data-shop1"},{"id":"shop2","name":"Shop 2","dataDir":"/home/u123/bot-data-shop2"}]
BOTS_CONFIG=

# ===== PayOS (https://my.payos.vn) =====
# Lấy trong: Kênh thanh toán -> Thông tin xác thực
PAYOS_CLIENT_ID=your-client-id
PAYOS_API_KEY=your-api-key
PAYOS_CHECKSUM_KEY=your-checksum-key

# Tùy chọn: URL trả về sau thanh toán (không bắt buộc với bot)
PAYOS_RETURN_URL=https://payos.vn
PAYOS_CANCEL_URL=https://payos.vn
